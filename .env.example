# Copy this file to `.env` and fill in your values:
#   cp .env.example .env
#
# WHERE TO FIND THESE IN SUPABASE:
# 1. Open https://supabase.com/dashboard
# 2. Select your project (Emerald-Summit-App)
# 3. Click the gear icon at the bottom left → "Project Settings"
# 4. Click "API" in the left menu
# 5. Under "Project URL" → copy into SUPABASE_URL
# 6. Under "Project API keys" → copy the "anon" "public" key into SUPABASE_ANON_KEY
#    (Use the anon key only — never put the service_role key in the app.)

SUPABASE_URL=https://spsxfbvamwxsmtjkwxko.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here